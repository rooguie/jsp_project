<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="userMapper">
	<insert id="join">
		INSERT INTO user(id,pw,email,phone) VALUES (#{id},#{pw},#{email},#{phone})
	</insert>


	<select id="login" resultType="domain.User">
		SELECT * FROM user WHERE id=#{id} AND pw=#{pw}
	</select>

	<update id="lastLoginUpdate">
		UPDATE user SET lastlogin=now() WHERE id=#{id}
	</update>

	<update id="userUpdate">
		UPDATE user SET pw=#{pw}, email=#{email}, phone=#{phone} WHERE id=#{id}
	</update>
	
	<delete id="deleteUser">
		DELETE FROM user WHERE id=#{id}
	</delete>
	
	
</mapper>