<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
<mapper namespace="boardMapper">
 	<insert id="add">
 		INSERT board(title, writer, contents) VALUES(#{title}, #{writer}, #{contents})
 	</insert>
 	
 	<select id="selectList" resultType="domain.Board">
 		SELECT * FROM board ORDER BY bno DESC
 	</select>
 	
 	<select id="detail" resultType="domain.Board">
 		SELECT * FROM board WHERE bno=#{bno}
 	</select>
 	
 	<select id="modify" resultType="domain.Board">
 		SELECT * FROM board WHERE bno=#{bno}
 	</select>
 	
 	<select id="update">
 		UPDATE board SET title=#{title}, contents=#{contents}, moddate=now() WHERE bno=#{bno}
 	</select>
 	
 	<delete id="delete">
 		DELETE FROM board WHERE bno=#{bno}
 	</delete>
 
 	<select id="myList" resultType="domain.Board">
		SELECT * FROM board WHERE writer=#{writer}
	</select>
 
</mapper>